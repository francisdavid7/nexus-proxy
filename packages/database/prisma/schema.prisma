generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  CUSTOMER
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DISABLED
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum CredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum DeviceStatus {
  ACTIVE
  REVOKED
}

enum NodeStatus {
  PROVISIONING
  ONLINE
  DEGRADED
  OFFLINE
  MAINTENANCE
}

enum ProxyProtocol {
  HTTP
  HTTPS
  SOCKS5
}

enum SessionStatus {
  ACTIVE
  CLOSED
  FAILED
}

enum SecuritySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  fullName        String     @map("full_name") @db.VarChar(120)
  email           String     @unique @db.VarChar(255)
  passwordHash    String     @map("password_hash") @db.VarChar(255)
  role            UserRole   @default(CUSTOMER)
  status          UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  ownedOrganizations Organization[]       @relation("OrganizationOwner")
  memberships       OrganizationMember[]
  credentials       ProxyCredential[]
  devices           Device[]
  sessions          ConnectionSession[]
  apiKeys           ApiKey[]
  usageRecords      UsageRecord[]
  auditLogs         AuditLog[]            @relation("AuditActor")
  securityEvents    SecurityEvent[]

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  slug      String   @unique @db.VarChar(120)
  ownerId   String   @map("owner_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner          User                @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members        OrganizationMember[]
  subscriptions  Subscription[]
  credentials    ProxyCredential[]
  devices        Device[]
  sessions       ConnectionSession[]
  usageRecords   UsageRecord[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  securityEvents SecurityEvent[]

  @@index([ownerId])
  @@map("organizations")
}

model OrganizationMember {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Plan {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String   @unique @db.VarChar(80)
  code                String   @unique @db.VarChar(50)
  monthlyPriceCents   Int      @map("monthly_price_cents")
  bandwidthLimitBytes BigInt?  @map("bandwidth_limit_bytes")
  deviceLimit         Int      @default(1) @map("device_limit")
  credentialLimit          Int      @default(1) @map("credential_limit")
  maxConcurrentConnections Int      @default(3) @map("max_concurrent_connections")
  connectionsPerMinute     Int      @default(60) @map("connections_per_minute")
  active                  Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationId       String             @map("organization_id") @db.Uuid
  planId               String             @map("plan_id") @db.Uuid
  status               SubscriptionStatus @default(TRIAL)
  currentPeriodStart   DateTime           @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime           @map("current_period_end") @db.Timestamptz(6)
  canceledAt           DateTime?          @map("canceled_at") @db.Timestamptz(6)
  externalCustomerId   String?            @map("external_customer_id") @db.VarChar(150)
  externalSubscription String?            @map("external_subscription_id") @db.VarChar(150)
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@index([planId])
  @@map("subscriptions")
}

model Location {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(50)
  countryCode String   @map("country_code") @db.Char(2)
  country     String   @db.VarChar(100)
  city        String   @db.VarChar(100)
  region      String?  @db.VarChar(100)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  nodes ProxyNode[]

  @@index([countryCode])
  @@map("locations")
}

model ProxyNode {
  id                String          @id @default(uuid()) @db.Uuid
  locationId        String          @map("location_id") @db.Uuid
  name              String          @unique @db.VarChar(120)
  hostname          String          @unique @db.VarChar(255)
  publicIp          String?         @map("public_ip") @db.VarChar(45)
  httpPort          Int             @default(8080) @map("http_port")
  tlsPort           Int             @default(8443) @map("tls_port")
  socksPort         Int             @default(1080) @map("socks_port")
  protocols         ProxyProtocol[]
  status            NodeStatus      @default(PROVISIONING)
  maxConnections    Int             @default(1000) @map("max_connections")
  activeConnections Int             @default(0) @map("active_connections")
  version           String?         @db.VarChar(50)
  lastHeartbeatAt   DateTime?       @map("last_heartbeat_at") @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  location       Location            @relation(fields: [locationId], references: [id], onDelete: Restrict)
  sessions       ConnectionSession[]
  usageRecords   UsageRecord[]
  securityEvents SecurityEvent[]

  @@index([locationId, status])
  @@index([status])
  @@map("proxy_nodes")
}

model Device {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  name           String       @db.VarChar(120)
  platform       String?      @db.VarChar(80)
  fingerprint    String?      @unique @db.VarChar(255)
  status         DeviceStatus @default(ACTIVE)
  lastSeenAt     DateTime?    @map("last_seen_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials  ProxyCredential[]
  sessions     ConnectionSession[]

  @@index([organizationId])
  @@index([userId, status])
  @@map("devices")
}

model ProxyCredential {
  id               String           @id @default(uuid()) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  deviceId         String?          @map("device_id") @db.Uuid
  username         String           @unique @db.VarChar(100)
  secretDigest     String           @unique @map("secret_digest") @db.VarChar(128)
  secretPrefix     String           @map("secret_prefix") @db.VarChar(16)
  status           CredentialStatus @default(ACTIVE)
  allowedProtocols ProxyProtocol[]  @map("allowed_protocols")
  expiresAt        DateTime?        @map("expires_at") @db.Timestamptz(6)
  lastUsedAt       DateTime?        @map("last_used_at") @db.Timestamptz(6)
  revokedAt        DateTime?        @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  device         Device?             @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  sessions       ConnectionSession[]
  usageRecords   UsageRecord[]
  securityEvents SecurityEvent[]

  @@index([organizationId, status])
  @@index([userId, status])
  @@index([deviceId])
  @@map("proxy_credentials")
}

model ApiKey {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  name           String    @db.VarChar(100)
  keyPrefix      String    @map("key_prefix") @db.VarChar(16)
  keyDigest      String    @unique @map("key_digest") @db.VarChar(128)
  lastUsedAt     DateTime? @map("last_used_at") @db.Timestamptz(6)
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz(6)
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@map("api_keys")
}

model ConnectionSession {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  credentialId   String        @map("credential_id") @db.Uuid
  nodeId         String        @map("node_id") @db.Uuid
  deviceId       String?       @map("device_id") @db.Uuid
  protocol       ProxyProtocol
  status         SessionStatus @default(ACTIVE)
  sourceIpDigest String?       @map("source_ip_digest") @db.VarChar(128)
  bytesUploaded  BigInt        @default(0) @map("bytes_uploaded")
  bytesDownloaded BigInt       @default(0) @map("bytes_downloaded")
  startedAt      DateTime      @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt        DateTime?     @map("ended_at") @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential   ProxyCredential @relation(fields: [credentialId], references: [id], onDelete: Restrict)
  node         ProxyNode       @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  device       Device?         @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([organizationId, startedAt])
  @@index([userId, startedAt])
  @@index([credentialId, status])
  @@index([nodeId, status])
  @@map("connection_sessions")
}

model UsageRecord {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  credentialId    String   @map("credential_id") @db.Uuid
  nodeId          String   @map("node_id") @db.Uuid
  periodStart     DateTime @map("period_start") @db.Timestamptz(6)
  periodEnd       DateTime @map("period_end") @db.Timestamptz(6)
  bytesUploaded   BigInt   @default(0) @map("bytes_uploaded")
  bytesDownloaded BigInt   @default(0) @map("bytes_downloaded")
  connectionCount Int      @default(0) @map("connection_count")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential   ProxyCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  node         ProxyNode       @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([credentialId, nodeId, periodStart, periodEnd])
  @@index([organizationId, periodStart])
  @@index([userId, periodStart])
  @@map("usage_records")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String   @db.VarChar(150)
  resourceType   String   @map("resource_type") @db.VarChar(100)
  resourceId     String?  @map("resource_id") @db.VarChar(100)
  ipDigest       String?  @map("ip_digest") @db.VarChar(128)
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model SecurityEvent {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String?          @map("organization_id") @db.Uuid
  userId         String?          @map("user_id") @db.Uuid
  credentialId   String?          @map("credential_id") @db.Uuid
  nodeId         String?          @map("node_id") @db.Uuid
  severity       SecuritySeverity
  type           String           @db.VarChar(120)
  description    String?
  metadata       Json?
  resolvedAt     DateTime?        @map("resolved_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  credential   ProxyCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  node         ProxyNode?       @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  @@index([severity, createdAt])
  @@index([organizationId, createdAt])
  @@index([nodeId, createdAt])
  @@map("security_events")
}
